<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <filter>
        <filter-name>CsrfFilter</filter-name>
        <filter-class>filter.CsrfFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CsrfFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <filter>
        <filter-name>SecurityHeaderFilter</filter-name>
        <filter-class>filter.SecurityHeaderFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>SecurityHeaderFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <servlet>
        <servlet-name>MemberServlet</servlet-name>
        <servlet-class>controller.MemberServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MemberServlet</servlet-name>
        <url-pattern>/members/*</url-pattern>
    </servlet-mapping>

    <!-- /assets/* 요청은 Tomcat DefaultServlet이 처리 (CSS, JS, 이미지 등 정적 파일) -->
    <servlet-mapping>
        <servlet-name>default</servlet-name>
        <url-pattern>/assets/*</url-pattern>
    </servlet-mapping>

    <security-constraint>
        <web-resource-collection>
            <web-resource-name>Upload Directory</web-resource-name>
            <url-pattern>/upload/*</url-pattern>
        </web-resource-collection>
        <auth-constraint/>
    </security-constraint>

    <resource-ref>
        <description>Oracle DB Connection Pool</description>
        <res-ref-name>jdbc/oracle</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>

    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <name>SESSIONID</name>
            <http-only>true</http-only>
        </cookie-config>
    </session-config>
    <!-- 4xx Client Errors -->
    <error-page><error-code>400</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>401</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>402</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>403</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>404</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>405</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>406</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>407</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>408</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>409</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>410</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>411</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>412</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>413</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>414</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>415</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>416</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>417</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>421</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>422</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>423</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>424</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>426</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>428</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>429</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>431</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>451</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <!-- 5xx Server Errors -->
    <error-page><error-code>500</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>501</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>502</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>503</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>504</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>505</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>507</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>508</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <error-page><error-code>511</error-code><location>/WEB-INF/html/error.jsp</location></error-page>
    <!-- 모든 Java 예외 -->
    <error-page>
        <exception-type>java.lang.Throwable</exception-type>
        <location>/WEB-INF/html/error.jsp</location>
    </error-page>

</web-app>
