<?xml version="1.0" encoding="UTF-8"?>
<Context>
    <Resource
        name="jdbc/mysql"
        auth="Container"
        type="javax.sql.DataSource"
        driverClassName="com.mysql.cj.jdbc.Driver"
        url="jdbc:mysql://localhost:3306/projectdb?serverTimezone=Asia/Seoul&amp;characterEncoding=UTF-8"
